══════════════════════════════ -->
<section id="tests" class="py-20 px-6 scroll-mt-24">
  <div class="max-w-7xl mx-auto">

    <div class="reveal mb-12 text-center">
      <span class="batch-tag badge-orange mb-3 inline-block">QA · Section III</span>
      <h2 class="font-display text-4xl md:text-5xl font-800 text-white mb-3">4 Free QA Tests</h2>
      <p class="text-ink-200 max-w-lg mx-auto text-sm leading-relaxed">Each test blends MCQs (with −1 penalty) and TITA questions across all four QA topic pillars, mirroring real CAT 2026 difficulty.</p>
