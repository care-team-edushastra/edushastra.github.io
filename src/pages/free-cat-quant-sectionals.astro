    </a>
    <span class="text-ink-700">·</span>
    <a href="free-cat-dilr-sectionals" class="hover:text-purple-400 transition-colors flex items-center gap-1">
      <span class="w-2 h-2 rounded-full bg-purple-400 inline-block"></span> DILR Tests
    </a>
    <span class="ml-auto">
      <a href="/cat-mocks/" class="hover:text-white transition-colors">← View all sectional tests</a>
    </span>
  </div>
</div>

