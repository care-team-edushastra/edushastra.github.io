          </div>
          <a href={TEST_LINKS[0]} class="block text-center bg-brand-500 hover:bg-brand-600 text-white text-sm font-semibold px-4 py-2.5 rounded-full transition-all cta-glow">
            Start Test 1 →
          </a>
        </div>
      </div>

      <!-- Test 2 -->
      <div class="reveal test-card glass rounded-3xl overflow-hidden border border-white/08">
