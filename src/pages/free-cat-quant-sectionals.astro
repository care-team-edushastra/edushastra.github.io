<!-- ══════════════════════════════
     QA TIPS
══════════════════════════════ -->
<section class="py-16 px-6 bg-ink-800/20">
  <div class="max-w-7xl mx-auto">
    <div class="reveal mb-10 text-center">
      <h2 class="font-display text-4xl md:text-5xl font-800 text-white">
        Score 99%ile in QA with <span class="text-brand-500">These Principles</span>
      </h2>
    </div>
    <div class="grid md:grid-cols-3 gap-5">
      {[
        { icon: "🎯", title: "Accuracy Over Speed", desc: "CAT QA's −1 penalty punishes guessing. Most toppers attempt 14–16 questions with near-perfect accuracy rather than rushing all 22. Our tests help you calibrate your personal attempt-accuracy sweet spot." },
        { icon: "📐", title: "Master Arithmetic First", desc: "40% of QA is Arithmetic — percentages, profit and loss, averages, mixtures, time-speed-distance. This is where the most marks are available and where disciplined practice pays off fastest." },
        { icon: "⚡", title: "TITA is Your Safety Net", desc: "8 of 22 QA questions are TITA (no negative marking). Build a strategy to solve these confidently — they're your guaranteed scoring opportunities and can be the difference between 85th and 95th %ile." },
      ].map(f => (
        <div class="reveal glass rounded-2xl p-6">
          <h4 class="font-display font-700 text-brand-500 text-xl mb-3">{f.icon} {f.title}</h4>
          <p class="text-white text-sm leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>

    <div class="reveal glass-orange rounded-3xl p-8 mt-10 flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <p class="font-display font-700 text-white text-xl mb-1">Want a structured QA curriculum?</p>
