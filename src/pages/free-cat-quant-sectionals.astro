          <h3 class="font-display text-xl font-700 text-white mb-2">Sectional Test 1</h3>
          <div class="flex gap-3 text-xs mb-6">
            <div class="glass rounded-lg px-3 py-2 text-center flex-1">
              <p class="font-display font-700 text-white">22</p>
              <p class="text-ink-400 mt-0.5">Questions</p>
            </div>
            <div class="glass rounded-lg px-3 py-2 text-center flex-1">
              <p class="font-display font-700 text-white">40 min</p>
