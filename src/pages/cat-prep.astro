<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CAT 2026 Prep: Personalized IQ-Based Batches | EduShastra</title>
  <meta name="description" content="Master CAT 2026 with EduShastra's scientific IQ-based batching. Personalized ability-based prep with 4-phase training. Target +99%ile with our Apex-25 batches." />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://www.edushastra.com/cat-2026/" />

  <meta property="og:title" content="CAT 2026 Prep: Personalized IQ-Based Batches | EduShastra" />
  <meta property="og:description" content="Master CAT 2026 with EduShastra's IQ-based batching. +99%ile or Fee Refund Promise." />
  <meta property="og:url" content="https://www.edushastra.com/cat-2026/" />
  <meta property="og:type" content="website" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />

  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            display: ['Syne', 'sans-serif'],
            body: ['DM Sans', 'sans-serif'],
          },
          colors: {
            brand: {
              50:  '#fff7ed',
              100: '#ffedd5',
              400: '#fb923c',
              500: '#f97316',
              600: '#ea6c0a',
              700: '#c2540a',
            },
            ink: {
              900: '#0d0d0d',
              800: '#1a1a1a',
              700: '#2d2d2d',
              400: '#6b6b6b',
              200: '#d4d4d4',
              100: '#f5f5f5',
            }
          },
          animation: {
            'marquee': 'marquee 35s linear infinite',
          },
          keyframes: {
            marquee: {
              '0%':   { transform: 'translateX(0)' },
              '100%': { transform: 'translateX(-50%)' },
            },
          }
        }
      }
    }
  </script>

  <style>
    body { font-family: 'DM Sans', sans-serif; background: #0d0d0d; color: #f5f5f5; }
    h1,h2,h3,h4,h5,.font-display { font-family: 'Syne', sans-serif; }

    body::before {
      content: '';
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      opacity: 0.35;
    }

    .hero-bg {
      background:
        radial-gradient(ellipse 70% 60% at 15% 50%, rgba(249,115,22,0.15) 0%, transparent 60%),
        radial-gradient(ellipse 50% 70% at 85% 20%, rgba(249,115,22,0.08) 0%, transparent 55%),
        #0d0d0d;
    }

    .glass {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.09);
      backdrop-filter: blur(12px);
    }

    .glass-orange {
      background: rgba(249,115,22,0.06);
      border: 1px solid rgba(249,115,22,0.2);
      backdrop-filter: blur(12px);
    }

    .nav-blur {
      background: rgba(13,13,13,0.8);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .cta-glow:hover { box-shadow: 0 0 32px rgba(249,115,22,0.5); }

    .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .revealed { opacity: 1; transform: translateY(0); }

    .slider-track { display: flex; gap: 1.5rem; transition: transform 0.5s cubic-bezier(0.4,0,0.2,1); }

    .batch-tag {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 3px 10px;
      border-radius: 999px;
    }

    .tier-card { transition: transform 0.3s ease, border-color 0.3s ease; }
    .tier-card:hover { transform: translateY(-4px); }

    .section-divider {
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(249,115,22,0.3), transparent);
      margin: 0 auto;
      width: 60%;
    }

    .table-row:nth-child(even) { background: rgba(255,255,255,0.02); }
    .table-row:hover { background: rgba(249,115,22,0.06); }
      /* ── Media scroller ── */
    .media-scroller {
      overflow: hidden;
      /* Fade out the left and right edges for a polished infinite feel */
      mask-image: linear-gradient(
        to right,
        transparent 0%,
        black 8%,
        black 92%,
        transparent 100%
      );
      -webkit-mask-image: linear-gradient(
        to right,
        transparent 0%,
        black 8%,
        black 92%,
        transparent 100%
      );
    }

    .media-track {
      display: flex;
      gap: 1.5rem;
      /* Each card is ~280px wide + 1.5rem gap; the track holds 8 cards (4 real + 4 clones)
         so translateX(-50%) always lands back at the start seamlessly */
      width: max-content;
      animation: marquee 40s linear infinite;
    }
@keyframes marquee {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
    /* Pause on hover so users can read the card */
    .media-track:hover {
      animation-play-state: paused;
    }

    .media-card {
      flex: 0 0 280px;         /* fixed width per card */
      transition: border-color 0.3s ease, transform 0.3s ease;
    }

    .media-card:hover {
      transform: translateY(4px);
    }

    /* Badge colors by mode */
    .badge-online  { background: rgba(59,130,246,0.15); color: #93c5fd; border: 1px solid rgba(59,130,246,0.3); }
    .badge-offline { background: rgba(34,197,94,0.12); color: #86efac; border: 1px solid rgba(34,197,94,0.25); }
    .badge-hybrid  { background: rgba(168,85,247,0.12); color: #d8b4fe; border: 1px solid rgba(168,85,247,0.25); }
  </style>
</head>

