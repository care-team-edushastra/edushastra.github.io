                      <img src={c.image} alt={c.label} class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500" loading="lazy" />

         </div>
        <p class="text-brand text-sm leading-relaxed whitespace-pre-line">
          {c.address}
        </p>
      </div>
    </div>
  </a>
))}



