══════════════════════════════ -->
<section id="tests" class="py-20 px-6 scroll-mt-24">
  <div class="max-w-7xl mx-auto">

    <div class="reveal mb-12 text-center">
      <span class="batch-tag badge-purple mb-3 inline-block">DILR · Section II</span>
      <h2 class="font-display text-4xl md:text-5xl font-800 text-white mb-3">4 Free DILR Tests</h2>
