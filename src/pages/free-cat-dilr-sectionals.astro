      <!-- Test 1 -->
      <div class="reveal test-card glass rounded-3xl overflow-hidden border border-white/08">
        <div class="h-1 bg-gradient-to-r from-purple-700 to-purple-400"></div>
        <div class="p-6">
          <div class="flex items-center justify-between mb-4">
            <span class="batch-tag badge-purple">DILR</span>
