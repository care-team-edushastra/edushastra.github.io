<!-- ══════════════════════════════
     DILR TIPS
══════════════════════════════ -->
<section class="py-16 px-6 bg-ink-800/20">
  <div class="max-w-7xl mx-auto">
    <div class="reveal mb-10 text-center">
      <h2 class="font-display text-4xl md:text-5xl font-800 text-white">
        The DILR <span class="text-purple-400">Strategy That Works</span>
      </h2>
    </div>
    <div class="grid md:grid-cols-3 gap-5">
      {[
        { icon: "🔍", title: "Set Selection Is Half the Battle", desc: "In 40 minutes you can't solve all 4 sets well. The skill is reading each set's first question in 60 seconds and deciding which two sets to bet on. Our tests train you to make this call under pressure." },
        { icon: "📐", title: "Crack the Pattern, Not the Data", desc: "DILR rewards pattern recognition over raw calculation. Focus on constraints and logic structure first — the numbers follow. This mindset shift is what moves aspirants from 70th to 90th %ile." },
        { icon: "🧠", title: "Simulate Before the Actual Exam", desc: "DILR is the most unpredictable CAT section year to year. Exposure to diverse set types — our tests cover 16+ set varieties — is the only real insurance against a curveball paper." },
      ].map(f => (
        <div class="reveal glass rounded-2xl p-6">
          <h4 class="font-display font-700 text-purple-400 text-xl mb-3">{f.icon} {f.title}</h4>
          <p class="text-white text-sm leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>

    <div class="reveal glass-purple rounded-3xl p-8 mt-10 flex flex-col md:flex-row items-center justify-between gap-6">
      <div>
        <p class="font-display font-700 text-white text-xl mb-1">Want structured DILR training?</p>
        <p class="text-ink-200 text-sm">Our DILR modules in Elite and Apex-25 include 50+ sets with live faculty walkthroughs and strategy sessions.</p>
