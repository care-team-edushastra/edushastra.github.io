---
// EduShastra — DILR Free Sectional Tests Page (Astro)
// Purple accent | CAT 2026 design system: dark bg, glassmorphism, Syne + DM Sans
const TEST_LINKS = [
  "https://edushastra-free.onrender.com/dilr-1",
  "https://edushastra-free.onrender.com/dilr-2",
  "https://edushastra-free.onrender.com/dilr-3",
  "https://edushastra-free.onrender.com/dilr-4",
];
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CAT DILR Sectional Tests (Free) | CAT 2026 LRDI Practice</title>
    <link rel="icon" href="https://www.edushastra.com/wp-content/uploads/2024/09/eduShastra-logo_only-100x100.png" sizes="32x32"><link rel="icon" href="https://www.edushastra.com/wp-content/uploads/2024/09/eduShastra-logo_only-300x300.png" sizes="192x192">
  <meta name="description" content="Practice high-quality CAT DILR sectional tests covering Data Interpretation and Logical Reasoning. Get instant analysis, detailed solutions, and improve your CAT 2026 score." />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://www.edushastra.com/free-sectional-tests/dilr/" />

  <meta property="og:title" content="CAT DILR Sectional Tests (Free) | CAT 2026 LRDI Practice" />
  <meta property="og:description" content="Practice high-quality CAT DILR sectional tests covering Data Interpretation and Logical Reasoning. Get instant analysis, detailed solutions, and improve your CAT 2026 score." />
  <meta property="og:url" content="https://www.edushastra.com/free-sectional-tests/dilr/" />
  <meta property="og:type" content="website" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />

  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            display: ['Syne', 'sans-serif'],
            body: ['DM Sans', 'sans-serif'],
          },
          colors: {
            accent: {
              50:  '#faf5ff',
              100: '#f3e8ff',
              400: '#c084fc',
              500: '#a855f7',
              600: '#9333ea',
              700: '#7e22ce',
            },
            brand: {
              500: '#f97316',
              600: '#ea6c0a',
            },
            ink: {
              900: '#0d0d0d',
              800: '#1a1a1a',
              700: '#2d2d2d',
              400: '#6b6b6b',
              200: '#d4d4d4',
              100: '#f5f5f5',
            }
          },
        }
      }
    }
  </script>

  <style>
    body { font-family: 'DM Sans', sans-serif; background: #0d0d0d; color: #f5f5f5; }
    h1,h2,h3,h4,h5,.font-display { font-family: 'Syne', sans-serif; }

    body::before {
      content: '';
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      opacity: 0.35;
    }

    .hero-bg {
      background:
        radial-gradient(ellipse 70% 60% at 15% 50%, rgba(168,85,247,0.18) 0%, transparent 60%),
        radial-gradient(ellipse 50% 70% at 85% 20%, rgba(168,85,247,0.08) 0%, transparent 55%),
        #0d0d0d;
    }

    .glass {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.09);
      backdrop-filter: blur(12px);
    }

    .glass-purple {
      background: rgba(168,85,247,0.06);
      border: 1px solid rgba(168,85,247,0.2);
      backdrop-filter: blur(12px);
    }

    .nav-blur {
      background: rgba(13,13,13,0.8);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .cta-glow:hover { box-shadow: 0 0 32px rgba(168,85,247,0.45); }
    .cta-orange:hover { box-shadow: 0 0 32px rgba(249,115,22,0.5); }

    .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .revealed { opacity: 1; transform: translateY(0); }

    .batch-tag {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 3px 10px;
      border-radius: 999px;
    }

    .badge-purple { background: rgba(168,85,247,0.12); color: #d8b4fe; border: 1px solid rgba(168,85,247,0.3); }
    .badge-orange { background: rgba(249,115,22,0.12); color: #fb923c; border: 1px solid rgba(249,115,22,0.3); }

    .test-card { transition: transform 0.25s ease, border-color 0.25s ease; }
    .test-card:hover { transform: translateY(-4px); border-color: rgba(168,85,247,0.35) !important; }

    .topic-chip {
      font-size: 11px;
      font-weight: 500;
      color: #d8b4fe;
      background: rgba(168,85,247,0.08);
      border: 1px solid rgba(168,85,247,0.2);
      border-radius: 999px;
      padding: 3px 10px;
      white-space: nowrap;
    }

    .progress-bar {
      height: 3px;
      border-radius: 999px;
      background: rgba(255,255,255,0.06);
      overflow: hidden;
    }
    .progress-fill {
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, #7e22ce, #c084fc);
    }

    /* Difficulty pill */
    .diff-hard { font-size: 10px; font-weight: 600; color: #fca5a5; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); border-radius: 999px; padding: 2px 8px; }
    .diff-med  { font-size: 10px; font-weight: 600; color: #fcd34d; background: rgba(234,179,8,0.1);  border: 1px solid rgba(234,179,8,0.2);  border-radius: 999px; padding: 2px 8px; }
    .diff-easy { font-size: 10px; font-weight: 600; color: #86efac; background: rgba(34,197,94,0.1);  border: 1px solid rgba(34,197,94,0.2);  border-radius: 999px; padding: 2px 8px; }
  </style>
</head>

<body class="relative overflow-x-hidden">

<!-- ══════════════════════════════
     NAVBAR
══════════════════════════════ -->
<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 nav-blur">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2">
      <span class="font-display text-2xl font-800 text-white tracking-tight">Edu<span class="text-brand-500">Shastra</span></span>
    </a>
    <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-ink-200">
      <li><a href="https://www.edushastra.com/courses/" class="hover:text-purple-400 transition-colors">Courses</a></li>
      <li><a href="https://www.edushastra.com/cat-2026/#batches" class="hover:text-purple-400 transition-colors">Batches</a></li>
      <li><a href="https://www.edushastra.com/free-sectional-tests/" class="hover:text-purple-400 transition-colors">All Free Tests</a></li>
      <li><a href="https://www.edushastra.com/cat-2026/#faculty" class="hover:text-purple-400 transition-colors">Faculty</a></li>
      <li><a href="#faqs" class="hover:text-purple-400 transition-colors">FAQs</a></li>
    </ul>
    <div class="flex items-center gap-3">
      <a href="https://www.edushastra.com/login/" class="hidden md:block text-sm text-ink-200 hover:text-white transition-colors px-4 py-2">Login</a>
      <a href="#tests" class="cta-glow bg-purple-600 hover:bg-purple-700 text-white text-sm font-semibold px-5 py-2.5 rounded-full transition-all duration-300">
        Start a Test →
      </a>
      <button id="menuBtn" class="md:hidden text-white p-1" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>
  <div id="mobileMenu" class="hidden md:hidden px-6 pb-6 pt-2 flex flex-col gap-4 text-sm font-medium text-ink-200">
    <a href="#tests">All Tests</a>
    <a href="https://www.edushastra.com/cat-2026/#batches">Batches</a>
    <a href="https://www.edushastra.com/cat-2026/#faculty">Faculty</a>
    <a href="#faqs">FAQs</a>
    <a href="https://www.edushastra.com/login/">Login</a>
  </div>
</nav>

<!-- ══════════════════════════════
     HERO
══════════════════════════════ -->
<section class="hero-bg relative min-h-[75vh] flex items-center pt-32 pb-16 px-6">
  <div class="max-w-7xl mx-auto w-full relative z-10 grid lg:grid-cols-2 gap-12 items-center">
    <div>
      <div class="inline-flex items-center gap-2 bg-purple-500/10 border border-purple-500/30 rounded-full px-4 py-1.5 text-purple-400 text-xs font-semibold tracking-widest uppercase mb-6">
        <span class="w-1.5 h-1.5 bg-purple-400 rounded-full animate-pulse"></span>
        Section II · 100% Free · No Signup Fee
      </div>

      <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-800 leading-[1.05] text-white mb-6">
        Free DILR<br/>
        <span class="text-purple-400">Sectional Tests</span>
      </h1>

      <p class="text-lg text-ink-200 max-w-xl leading-relaxed mb-8">
        Full-length DILR mocks built to the exact CAT 2026 pattern. Master data caselets, LR puzzles and analytical sets — the section that surprises most aspirants on exam day.
      </p>

      <div class="flex flex-wrap gap-3 mb-10">
        <span class="glass rounded-full px-4 py-2 text-sm font-medium text-white">⏱️ 40 Minutes</span>
        <span class="glass rounded-full px-4 py-2 text-sm font-medium text-white">📝 20 Questions (MCQ + TITA)</span>
        <span class="glass rounded-full px-4 py-2 text-sm font-medium text-white">📊 Instant Score & Analysis</span>
      </div>

      <a href="#tests" class="inline-block cta-glow bg-purple-600 hover:bg-purple-700 text-white font-semibold px-8 py-3.5 rounded-full transition-all duration-300 text-base">
        Jump to Tests ↓
      </a>
    </div>

    <!-- DI/LR split card -->
    <div class="glass-purple rounded-3xl p-8 space-y-6 hidden lg:block">
      <p class="font-display font-700 text-white text-lg mb-2">What's tested in DILR?</p>
      {[
        { label: "Data Interpretation (DI)", pct: 50, note: "Tables, bar/line charts, pie charts, caselets" },
        { label: "Logical Reasoning (LR)", pct: 50, note: "Seating, scheduling, blood relations, puzzles" },
      ].map(t => (
        <div>
          <div class="flex justify-between text-sm mb-1.5">
            <span class="text-ink-200">{t.label}</span>
            <span class="text-purple-400 font-semibold">{t.pct}%</span>
          </div>
          <div class="progress-bar"><div class="progress-fill" style={`width:${t.pct}%`}></div></div>
          <p class="text-ink-400 text-xs mt-1">{t.note}</p>
        </div>
      ))}

      <div class="border-t border-white/08 pt-5 space-y-3">
        <p class="font-display font-600 text-white text-sm">Sets you'll encounter:</p>
        <div class="flex flex-wrap gap-2">
          {["Bar Charts", "Line Graphs", "Pie Charts", "Seating Arrangement", "Scheduling", "Blood Relations", "Venn Diagrams", "Caselets"].map(s => (
            <span class="topic-chip">{s}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════
     OTHER SECTIONS BREADCRUMB
══════════════════════════════ -->
<div class="py-4 px-6 border-b border-white/06 bg-ink-800/30">
  <div class="max-w-7xl mx-auto flex flex-wrap gap-3 items-center text-sm text-ink-400">
    <span>Also free:</span>
    <a href="/free-cat-varc-sectionals/" class="hover:text-blue-400 transition-colors flex items-center gap-1">
