---
// EduShastra — Daily Practice Page (Astro)
// Matches CAT 2026 / CUET design: dark bg, orange accent, glassmorphism, Syne + DM Sans
const TEST_LINK = "https://edushastra-free.onrender.com/"; // placeholder — same link for every test

// 6 static card slots — actual dates are filled in client-side (see script at
// the bottom) so the page always shows "today" back through "today - 5",
// without needing a rebuild. data-day-offset tells the script which date
// belongs in which card.
const dailyCardSlots = [0, 1, 2, 3, 4, 5];
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
