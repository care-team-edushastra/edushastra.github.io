---
// EduShastra — About Us Page (Astro)
// Matches Contact Us design: dark bg, orange accent, glassmorphism, Syne + DM Sans
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>About EduShastra | Affordable Quality Education & Global Services</title>
  <meta name="description" content="EduShastra is an Education & Real Estate Group founded by IIT, IIM and Ivy League alumni. We offer world-class CAT, GMAT, CUET preparation at affordable prices, built on the philosophy of 'For People, Not Profits'." />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://www.edushastra.com/about-us/" />

  <meta property="og:title" content="About EduShastra | Affordable Quality Education" />
  <meta property="og:description" content="Founded by IIT, IIM, Ivy League alumni. 130–170% YoY growth. Zero marketing. For People, Not Profits." />
  <meta property="og:url" content="https://www.edushastra.com/about-us/" />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://www.edushastra.com/wp-content/uploads/2020/07/card-header.jpg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />

  <script is:inline src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            display: ['Syne', 'sans-serif'],
            body: ['DM Sans', 'sans-serif'],
          },
          colors: {
            brand: {
              50:  '#fff7ed',
              100: '#ffedd5',
              400: '#fb923c',
              500: '#f97316',
              600: '#ea6c0a',
              700: '#c2540a',
            },
            ink: {
              900: '#0d0d0d',
              800: '#1a1a1a',
              700: '#2d2d2d',
              400: '#6b6b6b',
              300: '#a3a3a3',
              200: '#d4d4d4',
              100: '#f5f5f5',
            }
          }
        }
      }
    }
  </script>

  <style>
    body { font-family: 'DM Sans', sans-serif; background: #0d0d0d; color: #f5f5f5; }
    h1,h2,h3,h4,h5,.font-display { font-family: 'Syne', sans-serif; }

    /* Noise texture overlay */
    body::before {
      content: '';
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      opacity: 0.35;
    }

    .hero-bg {
      background:
        radial-gradient(ellipse 70% 60% at 15% 50%, rgba(249,115,22,0.15) 0%, transparent 60%),
        radial-gradient(ellipse 50% 70% at 85% 20%, rgba(249,115,22,0.08) 0%, transparent 55%),
        #0d0d0d;
    }

    .glass {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.09);
      backdrop-filter: blur(12px);
    }

    .glass-orange {
      background: rgba(249,115,22,0.08);
      border: 1px solid rgba(249,115,22,0.2);
      backdrop-filter: blur(12px);
    }

    .nav-blur {
      background: rgba(13,13,13,0.8);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .cta-glow:hover { box-shadow: 0 0 32px rgba(249,115,22,0.5); }

    /* Reveal animation */
    .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .revealed { opacity: 1; transform: translateY(0); }

    /* Stat counter cards */
    .stat-card { transition: all 0.3s ease; }
    .stat-card:hover { transform: translateY(-6px); border-color: rgba(249,115,22,0.4); box-shadow: 0 20px 60px rgba(249,115,22,0.1); }

    /* Mission item */
    .mission-card { transition: all 0.3s ease; }
    .mission-card:hover { transform: translateY(-4px); border-color: rgba(249,115,22,0.3); }

    /* Ticker animation */
    @keyframes ticker {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .ticker-inner { animation: ticker 30s linear infinite; }
    .ticker-inner:hover { animation-play-state: paused; }

    /* Checkmark list */
    .check-list li {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 12px 0;
      border-bottom: 1px solid rgba(255,255,255,0.07);
      font-weight: 500;
      color: rgba(212,212,212,0.9);
    }
    .check-list li:last-child { border-bottom: none; }
    .check-list li::before {
      content: '✓';
      color: #f97316;
      font-weight: 700;
      flex-shrink: 0;
      margin-top: 1px;
    }

    /* Timeline */
    .timeline-item { position: relative; padding-left: 2rem; }
    .timeline-item::before {
      content: '';
      position: absolute; left: 0; top: 6px;
      width: 10px; height: 10px;
      border-radius: 50%;
      background: #f97316;
      box-shadow: 0 0 12px rgba(249,115,22,0.6);
    }
    .timeline-item::after {
      content: '';
      position: absolute; left: 4px; top: 20px;
      width: 2px;
      height: calc(100% - 10px);
      background: linear-gradient(to bottom, rgba(249,115,22,0.4), transparent);
    }
    .timeline-item:last-child::after { display: none; }

    /* Accent line */
    .accent-line {
      display: block;
      width: 60px; height: 3px;
      background: linear-gradient(90deg, #f97316, transparent);
      border-radius: 2px;
      margin-bottom: 1.5rem;
    }

    /* Orange number counter */
    .big-stat { font-family: 'Syne', sans-serif; font-weight: 800; color: #f97316; line-height: 1; }
  </style>
</head>

<body class="relative overflow-x-hidden">

